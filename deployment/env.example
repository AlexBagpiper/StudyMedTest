# --- General Settings ---
PROJECT_NAME=MedTest Platform
ENVIRONMENT=production
VERSION=1.0.1

# --- Database Configuration ---
POSTGRES_SERVER=db
POSTGRES_USER=medtest_user
POSTGRES_PASSWORD=secure_password_change_me
POSTGRES_DB=medtest_db
# DATABASE_URL can be built automatically from parts above.
# DATABASE_URL=postgresql+asyncpg://medtest_user:secure_password_change_me@db:5432/medtest_db

# --- Redis & Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Security ---
# Generate a strong secret key: openssl rand -hex 32
SECRET_KEY=generate_a_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Object Storage (MinIO) ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password_change_me
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_password_change_me
MINIO_BUCKET=medtest-storage
MINIO_SECURE=False
# URL used by frontend to access files. 
# If using Nginx proxy as configured: /storage
MINIO_PUBLIC_URL=/storage

# --- LLM Services ---
LLM_STRATEGY=yandex
LOCAL_LLM_ENABLED=False
LOCAL_LLM_URL=http://host.docker.internal:11434
LOCAL_LLM_MODEL=mistral-7b-instruct

# External LLM Keys (Optional)
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
YANDEX_API_KEY=your_yandex_key
YANDEX_FOLDER_ID=your_folder_id
YANDEX_SEARCH_API_KEY=your_yandex_search_key
YANDEX_SEARCH_FOLDER_ID=your_search_folder_id

# New Cloud Providers
DEEPSEEK_API_KEY=your_deepseek_key
QWEN_API_KEY=your_qwen_key
GIGACHAT_CREDENTIALS=your_gigachat_credentials
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# --- Email ---
SMTP_HOST=mail.med-testing.ru
SMTP_PORT=465
SMTP_USER=account@med-testing.ru
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=noreply@med-testing.ru

# Email transport: "celery" (prod — через очередь) или "sync" (dev fallback).
EMAIL_TRANSPORT=celery

# --- Registration / OTP policy ---
# Все параметры опциональны — дефолты из app/core/config.py.
# Раскомментируйте только если нужно переопределить.
# OTP_LENGTH=6
# OTP_TTL_SECONDS=600
# OTP_MAX_ATTEMPTS=5
# OTP_RESEND_COOLDOWN_SECONDS=60
# OTP_MAX_RESENDS_PER_HOUR=5
# REGISTRATION_DRAFT_TTL_SECONDS=900
# REGISTER_RATE_LIMIT_PER_IP=10/hour
# RESEND_RATE_LIMIT_PER_IP=20/hour
# VERIFY_RATE_LIMIT_PER_IP=30/minute
# RATE_LIMIT_STORAGE_URL=redis://redis:6379/4

# --- Monitoring ---
SENTRY_DSN=
LOG_LEVEL=INFO

# --- Initial Admin User ---
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=admin123_change_me

# --- Frontend ---
# In production with Nginx proxy, this is usually /api/v1
# Leave empty to use default /api/v1 (which works with nginx proxy)
# Or set to full URL if deploying frontend separately from backend
VITE_API_URL=/api/v1
